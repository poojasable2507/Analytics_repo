WITH source AS (
    SELECT *
    FROM raw.zip_to_terr
),

final AS (
    SELECT
        TRIM(zip_code)                      AS zip_code,
        TRIM(territory_id)                  AS territory_id,
        INITCAP(TRIM(territory_name))       AS territory_name,
        INITCAP(TRIM(region_name))          AS region_name,
        CURRENT_TIMESTAMP()                 AS record_loaded_at
    FROM source
)

SELECT *
FROM final